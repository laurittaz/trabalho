body {
	font-family: Arial, sams-serif;
	background-color: Pink;
	padding: 20px;	
}

h1 {
	text-align: center;
}
table {
	width:100%;
	margin: 0 auto;
	border-collapse: collapse;
	background-color: #EFCEF2;
}

th {
	background-color: #D386DB;
	color: purple;
	padding: 10px;	
}
 td{
	 padding: 10px;
	 text-align: center;
	 border: 1px solid #ccc;
 }
 tr:nth-child(even) {
	 background-color:#D386DB;
 }
 tr:hover {
	 background-color: #FFADF3;
 }

